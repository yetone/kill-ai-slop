---
import T from "./T.astro";
import { demos } from "../data/demos";

interface Props {
  id: string; // key into demos map
}
const { id } = Astro.props;
const demo = demos[id];
if (!demo) throw new Error(`No demo for id "${id}"`);
---

<figure class="ba" data-demo={id} data-show="before">
  <div class="ba-head">
    <div class="ba-switch" role="group" aria-label="Before / after">
      <span class="ba-thumb no-anim" aria-hidden="true"></span>
      <button type="button" data-ba="before" aria-pressed="true">
        <span class="dot slop" aria-hidden="true"></span>
        <span class="ba-lbl">
          <span class="ba-lbl-live"><T zh="slop" en="Slop" ja="Slop" ko="Slop" /></span>
          <span class="ba-lbl-ghost" aria-hidden="true"><T zh="slop" en="Slop" ja="Slop" ko="Slop" /></span>
        </span>
      </button>
      <button type="button" data-ba="after" aria-pressed="false">
        <span class="dot clean" aria-hidden="true"></span>
        <span class="ba-lbl">
          <span class="ba-lbl-live"><T zh="清理后" en="Clean" ja="クリーン" ko="정리 후" /></span>
          <span class="ba-lbl-ghost" aria-hidden="true"><T zh="清理后" en="Clean" ja="クリーン" ko="정리 후" /></span>
        </span>
      </button>
    </div>
  </div>

  <div class={`ba-stage demo-${id}`}>

    {/* .ba-clip / .ba-unclip are inert block wrappers except while the sweep
        plays: then a static feathered mask hangs on .ba-clip and the pair
        translate in opposite directions — the mask window sweeps across
        stationary content. See the sweep CSS below for why (Safari can't
        animate mask-position; it CAN animate transforms). */}
    <div class="ba-pane" data-pane="before">
      <div class="ba-clip"><div class="ba-unclip">
        <Fragment set:html={demo.before} />
      </div></div>
    </div>
    <div class="ba-pane" data-pane="after">
      <div class="ba-clip"><div class="ba-unclip">
        <Fragment set:html={demo.after} />
      </div></div>
    </div>

    {/* Dust-sweep transition overlay — plays only on Slop → Clean. */}
    <div class="ba-sweep" aria-hidden="true">
      <i class="mote m1"></i><i class="mote m2"></i><i class="mote m3"></i>
      <i class="mote m4"></i><i class="mote m5"></i><i class="mote m6"></i>
      <i class="mote m7"></i><i class="mote m8"></i><i class="mote m9"></i>
      <i class="mote m10"></i><i class="mote m11"></i><i class="mote m12"></i>
      <i class="mote m13"></i><i class="mote m14"></i><i class="mote m15"></i>
      <i class="mote m16"></i><i class="mote m17"></i><i class="mote m18"></i>
    </div>
  </div>
</figure>

<style>
  /* De-carded: the demo is no longer a floating rounded card. No outer border,
     radius, or shadow — each demo reads as an editorial inset in the article,
     the way a figure sits in a page of prose. The only shaped surfaces left are
     the functional Slop/Clean toggle and the specimens themselves. This also
     brings the demos back in line with the site's own token rule ("hairline
     rules instead of drop shadows"), which the card treatment had drifted from. */
  .ba {
    margin: 0;
    background: transparent;
    /* Tempo multiplier for the whole sweep (band, masks, dust, total run).
       1 is the original 840ms wipe; 1.35 (~1.13s wipe, ~1.4s total) lingers
       just long enough that the reveal registers as a crafted moment without
       ever feeling like it's making the user wait. */
    --sweep-t: 1.35;
  }
  .ba-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--s-4);
    padding: 0 0 var(--s-3);
    background: transparent;
  }
  /* A flat, light control: one hairline rectangle split down the middle by a
     single divider. No recessed track, no raised thumb, no shadow — the active
     side is marked in place by a faint wash, ink-weight text, and a lit dot. */
  .ba-switch {
    display: inline-flex;
    border: var(--hair) solid var(--rule);
    border-radius: var(--radius);
    overflow: clip;
  }
  /* No sliding thumb in the flat design — the selected segment is marked in
     place. The positioning script still runs, harmlessly, on this hidden node. */
  .ba-thumb {
    display: none;
  }
  /* Suppress the glide before the first measurement (initial paint) so the
     thumb doesn't fly in from the left. JS drops this class after positioning. */
  .ba-thumb.no-anim {
    transition: none;
  }
  .ba-switch button {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    appearance: none;
    border: 0;
    background: none;
    padding: 0.36rem 0.9rem;
    font: inherit;
    font-size: var(--step--1);
    letter-spacing: 0.004em;
    color: var(--ink-2);
    cursor: pointer;
    transition:
      color 180ms ease,
      background 180ms ease;
  }
  /* the single central divider */
  .ba-switch button + button {
    border-left: var(--hair) solid var(--rule);
  }
  .ba-switch button[aria-pressed="true"] {
    color: var(--ink);
    font-weight: 600;
    background: color-mix(in oklab, var(--ink) 5%, transparent);
  }
  /* Reserve each label's *bold* width in both states, so selecting a tab (which
     bolds it) never changes that tab's width — otherwise the whole switch would
     twitch wider/narrower on every toggle. A hidden, always-bold ghost fixes the
     width; the live copy stacks on top and carries the real (normal/bold) weight.
     Both run through <T>, so the reserved width tracks the active language. */
  .ba-lbl {
    display: inline-grid;
  }
  .ba-lbl-live,
  .ba-lbl-ghost {
    grid-area: 1 / 1;
  }
  .ba-lbl-ghost {
    font-weight: 600;
    visibility: hidden;
  }
  @media (prefers-reduced-motion: reduce) {
    .ba-thumb {
      transition: none;
    }
  }
  .dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    transition: opacity 180ms ease;
  }
  /* The inactive side recedes: its dot dims so only the selected segment reads
     as lit. */
  .ba-switch button:not([aria-pressed="true"]) .dot {
    opacity: 0.4;
  }
  .dot.slop {
    background: var(--slop);
  }
  .dot.clean {
    background: var(--mark);
  }
  .ba-hint {
    font-size: var(--step--1);
    color: var(--ink-3);
    /* Right-align the hint's edge with the SLOP tag below it: the head's 6px
       padding puts the hint 6px from the card edge, but the tag sits 0.6rem
       from the stage edge — close that gap so both right edges line up. */
    margin-right: calc(0.6rem - 6px);
  }
  @media (max-width: 34rem) {
    .ba-hint {
      display: none;
    }
  }

  .ba-stage {
    position: relative;
    overflow: clip;
    padding: clamp(1.25rem, 4vw, 2.5rem);
    min-height: 12rem;
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    place-items: center;
    /* Faintly recessed inset plate — with the outer card gone, this subtle
       step down from the page is what sets the specimen apart, no border or
       shadow needed. Softened to the large-surface radius so the specimen reads
       as an inset plate, not a cut rectangle. */
    background: var(--paper-2);
    border-radius: var(--radius-lg);
  }
  /* Both panes share one grid cell, so the stage always reserves the height of
     the taller pane — toggling slop ⇄ clean never resizes it, so the page
     can't jump. */
  .ba-pane {
    grid-area: 1 / 1;
    width: 100%;
  }
  /* Hide the inactive pane with visibility (not display) so it keeps taking up
     its space and the shared cell stays sized to the taller of the two. */
  .ba[data-show="before"] [data-pane="after"],
  .ba[data-show="after"] [data-pane="before"] {
    visibility: hidden;
  }
  /* While the sweep plays, both panes are visible and share one wipe edge:
     right of the edge only slop is painted, left of it only clean, so demos
     with transparent backgrounds can't leak the clean pane through the slop
     before the broom arrives. The two masks are exact complements (alphas sum
     to 1 across the ~10%-of-pane feather).

     Mechanism: the masks themselves are STATIC — WebKit/Safari cannot animate
     mask-position (the computed value interpolates but the paint doesn't
     follow) — so each pane's mask hangs on a .ba-clip wrapper whose gradient
     edge sits at the wrapper's left border, and the wrapper slides via
     translateX while .ba-unclip counter-slides by the exact inverse. Both are
     the pane's width, so the percentages cancel to the pixel: content stays
     put, only the mask window moves. Transforms interpolate everywhere.

     The edge is locked to the wipe front's TRAILING edge: the band's
     translateX spans -130%…300% of its own 45% width, i.e. -58.5% → 135% in
     stage terms — the same values the wrappers run, on the same bezier and
     clock, so band and reveal stay in lockstep throughout. `forwards` holds
     the end state (slop swept off, clean fully shown) until the overlay's
     fade removes .sweeping and the plain visibility rules take over — they
     show exactly the same thing, so nothing pops. */
  .ba.sweeping[data-show="after"] [data-pane="before"] {
    visibility: visible;
    z-index: 2;
  }
  .ba.sweeping[data-show="after"] .ba-clip {
    /* A mask's painting area is clipped to the element's BORDER BOX
       (mask-clip: border-box — WebKit enforces this strictly), so anything
       the counter-slide pushes outside the box would vanish, shadows
       included. Instead of relying on mask-clip: no-clip (patchy support),
       grow the border box itself: -200% side margins + the same padding make
       it 5 panes wide with the content area back in place, and -50%/50%
       vertically (margin/padding percentages all resolve against the pane's
       width) add half-a-pane of shadow headroom above and below. Net layout
       size is unchanged, so nothing jumps when the sweep starts. The mask
       then just covers the whole enlarged box; its 39–41% feather (2% of
       5 panes = 10% of the pane) sits exactly at the content area's left
       edge, and the box slides 1 pane's width = 20% of itself per 100%. */
    margin: -50% -200%;
    padding: 50% 200%;
    mask-size: 100% 100%;
    mask-position: 0 0;
    mask-repeat: no-repeat;
    animation: clip-slide calc(840ms * var(--sweep-t, 1))
      cubic-bezier(0.36, 0, 0.3, 1) forwards;
  }
  .ba.sweeping[data-show="after"] .ba-unclip {
    animation: unclip-slide calc(840ms * var(--sweep-t, 1))
      cubic-bezier(0.36, 0, 0.3, 1) forwards;
  }
  .ba.sweeping[data-show="after"] [data-pane="before"] .ba-clip {
    mask-image: linear-gradient(90deg, transparent 39%, #000 41%);
  }
  .ba.sweeping[data-show="after"] [data-pane="after"] .ba-clip {
    mask-image: linear-gradient(90deg, #000 39%, transparent 41%);
  }
  /* clip-slide percentages are of the ENLARGED (5-pane-wide) box: the pane
     travel of -58.5% → 135% divides by 5. unclip-slide stays in pane units. */
  @keyframes clip-slide {
    from { transform: translateX(-11.7%); }
    to   { transform: translateX(27%); }
  }
  @keyframes unclip-slide {
    from { transform: translateX(58.5%); }
    to   { transform: translateX(-135%); }
  }
  /* Tags are absolutely positioned, so display:none here has no height impact. */
  .ba[data-show="before"] .ba-tag.after,
  .ba[data-show="after"] .ba-tag.before {
    display: none;
  }

  .ba-tag {
    position: absolute;
    top: 0.6rem;
    right: 0.6rem;
    font-size: 0.62rem;
    letter-spacing: 0.14em;
    font-weight: 700;
    padding: 0.15rem 0.4rem;
    border-radius: var(--radius-sm);
    z-index: 3;
  }
  .ba-tag.before {
    color: #fff;
    background: var(--slop);
  }
  .ba-tag.after {
    color: var(--paper);
    background: var(--mark);
  }

  /* ── Dust-sweep transition ────────────────────────────────────────────
     Switching Slop → Clean sweeps the pane: a faint wipe front slides left →
     right and carries the dust off with it. The specks start visible, then
     get pushed sideways with a little motion blur — so it reads as being
     swept, not twinkling. Behind the front, the slop pane itself is masked
     away (see slop-erase above), so the clean pane surfaces in its wake.
     Removed under reduced-motion. `.ba-sweep`'s own fade is the JS
     end-signal. */
  .ba-sweep {
    position: absolute;
    inset: 0;
    z-index: 4;
    overflow: clip;
    pointer-events: none;
    opacity: 0;
  }
  /* the wipe front: a soft luminance band that passes across, clearing dust */
  .ba-sweep::before {
    content: "";
    position: absolute;
    top: -10%;
    bottom: -10%;
    left: 0;
    width: 45%;
    background: linear-gradient(
      90deg,
      transparent,
      color-mix(in oklab, var(--ink) 6%, transparent) 55%,
      transparent
    );
    opacity: 0;
    transform: translateX(-130%);
  }
  .mote {
    position: absolute;
    width: 2.5px;
    height: 2.5px;
    border-radius: 50%;
    /* dusty warm grey, not a bright speck */
    background: color-mix(in oklab, var(--ink-3) 82%, #9b7f5e);
    opacity: 0;
    filter: blur(0.3px);
  }
  /* dust scattered over the surface; swept off to the right */
  .m1  { left: 6%;  top: 40%; }
  .m2  { left: 11%; top: 66%; }
  .m3  { left: 15%; top: 26%; }
  .m4  { left: 20%; top: 52%; width: 4px; height: 4px; }
  .m5  { left: 25%; top: 74%; }
  .m6  { left: 30%; top: 34%; }
  .m7  { left: 35%; top: 60%; width: 1.5px; height: 1.5px; }
  .m8  { left: 40%; top: 22%; width: 4px; height: 4px; }
  .m9  { left: 45%; top: 48%; }
  .m10 { left: 50%; top: 71%; }
  .m11 { left: 55%; top: 30%; width: 1.5px; height: 1.5px; }
  .m12 { left: 60%; top: 56%; }
  .m13 { left: 65%; top: 42%; width: 4px; height: 4px; }
  .m14 { left: 70%; top: 68%; }
  .m15 { left: 76%; top: 24%; }
  .m16 { left: 81%; top: 50%; width: 1.5px; height: 1.5px; }
  .m17 { left: 86%; top: 72%; }
  .m18 { left: 91%; top: 36%; }

  .ba.sweeping .ba-sweep {
    animation: sweep-run calc(1040ms * var(--sweep-t, 1)) linear;
  }
  .ba.sweeping .ba-sweep::before {
    animation: wipe-front calc(840ms * var(--sweep-t, 1))
      cubic-bezier(0.36, 0, 0.3, 1) forwards;
  }
  .ba.sweeping .mote {
    /* ease-in: sit, then accelerate off — like being flicked by the sweep */
    animation: dust-sweep calc(430ms * var(--sweep-t, 1))
      cubic-bezier(0.42, 0, 0.7, 0.4) forwards;
  }
  .ba.sweeping .m1  { animation-delay: calc(20ms * var(--sweep-t, 1)); }
  .ba.sweeping .m2  { animation-delay: calc(50ms * var(--sweep-t, 1)); }
  .ba.sweeping .m3  { animation-delay: calc(80ms * var(--sweep-t, 1)); }
  .ba.sweeping .m4  { animation-delay: calc(110ms * var(--sweep-t, 1)); }
  .ba.sweeping .m5  { animation-delay: calc(145ms * var(--sweep-t, 1)); }
  .ba.sweeping .m6  { animation-delay: calc(180ms * var(--sweep-t, 1)); }
  .ba.sweeping .m7  { animation-delay: calc(215ms * var(--sweep-t, 1)); }
  .ba.sweeping .m8  { animation-delay: calc(250ms * var(--sweep-t, 1)); }
  .ba.sweeping .m9  { animation-delay: calc(285ms * var(--sweep-t, 1)); }
  .ba.sweeping .m10 { animation-delay: calc(320ms * var(--sweep-t, 1)); }
  .ba.sweeping .m11 { animation-delay: calc(355ms * var(--sweep-t, 1)); }
  .ba.sweeping .m12 { animation-delay: calc(390ms * var(--sweep-t, 1)); }
  .ba.sweeping .m13 { animation-delay: calc(425ms * var(--sweep-t, 1)); }
  .ba.sweeping .m14 { animation-delay: calc(455ms * var(--sweep-t, 1)); }
  .ba.sweeping .m15 { animation-delay: calc(485ms * var(--sweep-t, 1)); }
  .ba.sweeping .m16 { animation-delay: calc(510ms * var(--sweep-t, 1)); }
  .ba.sweeping .m17 { animation-delay: calc(535ms * var(--sweep-t, 1)); }
  .ba.sweeping .m18 { animation-delay: calc(560ms * var(--sweep-t, 1)); }

  @keyframes sweep-run {
    0%   { opacity: 0; }
    4%   { opacity: 1; }
    90%  { opacity: 1; }
    100% { opacity: 0; }
  }
  @keyframes wipe-front {
    0%   { opacity: 0; transform: translateX(-130%); }
    12%  { opacity: 1; }
    85%  { opacity: 1; }
    100% { opacity: 0; transform: translateX(300%); }
  }
  @keyframes dust-sweep {
    0%   { opacity: 0; transform: translate(0, 0) scale(1, 1); filter: blur(0.3px); }
    12%  { opacity: 0.62; transform: translate(1px, 0) scale(1, 1); }
    /* stretch into a horizontal streak as it's dragged off — a motion-blur
       trail, so it reads as dust being swept rather than a speck blinking */
    55%  { opacity: 0.5; transform: translate(16px, 1px) scale(2.6, 0.8); filter: blur(0.8px); }
    100% { opacity: 0; transform: translate(40px, 3px) scale(3.4, 0.5); filter: blur(1.6px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .ba-sweep { display: none; }
  }
</style>

<script>
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

  /* ── Sweep sound ─────────────────────────────────────────────────────────
     An elegant broom "whoosh" synthesised on the fly — no audio asset. A
     band-passed noise swell brightens and pans left → right to mirror the
     visual wipe front, then a light shimmer of bell partials rings out as the
     surface comes clean (the 灵动 lift). Built lazily inside the click handler
     so the AudioContext starts from a real user gesture, and shared across
     every BeforeAfter on the page. Only called when the sweep actually plays,
     so it inherits the reduced-motion gate too. */
  let audioCtx: AudioContext | null = null;

  function playSweepSound(tempo = 1) {
    // Muted by the top-right speaker toggle? Stay silent. (data-sound is the
    // single source of truth, resolved pre-paint and persisted to localStorage.)
    if (document.documentElement.dataset.sound === "off") return;
    try {
      const AC = window.AudioContext || (window as any).webkitAudioContext;
      if (!AC) return;
      if (!audioCtx) audioCtx = new AC();
      const ctx = audioCtx;
      if (ctx.state === "suspended") void ctx.resume();

      const now = ctx.currentTime;
      const out = ctx.createGain();
      out.gain.value = 0.85; // gentle master — this is UI ambience, not a game
      out.connect(ctx.destination);

      // One soft, lightly low-passed noise bed, reused by every layer below at
      // different read offsets — so nothing is a raw hiss and no two strokes
      // sound identical.
      const secs = 2.2;
      const frames = Math.floor(ctx.sampleRate * secs);
      const buf = ctx.createBuffer(1, frames, ctx.sampleRate);
      const ch = buf.getChannelData(0);
      let lp = 0;
      for (let i = 0; i < frames; i++) {
        const w = Math.random() * 2 - 1;
        lp = lp * 0.65 + w * 0.35; // darker low-pass — a soft "shhh" bed with
        ch[i] = lp; // the abrasive top end already gone at the source
      }
      const pan = (node: AudioNode, amount: number): AudioNode => {
        if (!ctx.createStereoPanner) return node;
        const p = ctx.createStereoPanner();
        p.pan.value = amount;
        node.connect(p);
        return p;
      };

      // ── One soft breath of air ───────────────────────────────────────────
      // The broom itself is nearly subliminal now: a single dark, low-passed
      // swell of air that glides across the stereo field with the wipe —
      // motion, not noise. Literal brush-noise kept reading as clatter no
      // matter how it was filtered, so for a UI flourish "pleasant" wins over
      // "realistic" and all the character moves into the pitched run below.
      {
        const dur = 0.8 * tempo;
        const src = ctx.createBufferSource();
        src.buffer = buf;
        const low = ctx.createBiquadFilter();
        low.type = "lowpass";
        low.Q.value = 0.5;
        low.frequency.value = 950;
        const g = ctx.createGain();
        g.gain.setValueAtTime(0.0001, now);
        g.gain.linearRampToValueAtTime(0.05, now + dur * 0.45);
        g.gain.exponentialRampToValueAtTime(0.0001, now + dur);
        src.connect(low).connect(g);
        let tail: AudioNode = g;
        if (ctx.createStereoPanner) {
          const p = ctx.createStereoPanner();
          p.pan.setValueAtTime(-0.6, now);
          p.pan.linearRampToValueAtTime(0.6, now + dur);
          g.connect(p);
          tail = p;
        }
        tail.connect(out);
        src.start(now, 0.1, dur + 0.05);
        src.stop(now + dur + 0.06);
      }

      // ── Sparkle run ──────────────────────────────────────────────────────
      // The sweep itself is melody: dust lifting off as a quick pentatonic
      // run, C5 climbing to C6 in six soft plucks under the wipe, panning
      // left → right with the band. Pentatonic means every interval lands
      // consonant, and closing on the octave (C5 → C6) already resolves the
      // phrase — no separate end-chime needed, the last pluck IS the "clean".
      const run = [
        { f: 523.25, at: 0.05 }, // C5
        { f: 587.33, at: 0.14 }, // D5
        { f: 659.25, at: 0.23 }, // E5
        { f: 783.99, at: 0.32 }, // G5
        { f: 880.0, at: 0.41 }, // A5
        { f: 1046.5, at: 0.5 }, // C6
      ];
      run.forEach(({ f, at }, i) => {
        const t0 = now + at * tempo;
        const osc = ctx.createOscillator();
        osc.type = "sine";
        osc.frequency.value = f;
        const g = ctx.createGain();
        const peak = 0.012 + i * 0.0016; // a gentle crescendo up the scale
        g.gain.setValueAtTime(0.0001, t0);
        g.gain.exponentialRampToValueAtTime(peak, t0 + 0.025);
        g.gain.exponentialRampToValueAtTime(0.0001, t0 + 0.4);
        osc.connect(g);
        pan(g, -0.55 + (i / (run.length - 1)) * 1.1).connect(out);
        osc.start(t0);
        osc.stop(t0 + 0.42);
      });
    } catch {
      /* audio is a nicety — never let it break the toggle */
    }
  }

  /* Warm the AudioContext on the first user gesture anywhere on the page, so
     the first sweep isn't swallowed by cold-start latency (a fresh context +
     async resume + audio-hardware wake-up can lag the very first sound). By the
     time the user reaches a toggle it's already running, and playback is tight.
     Browsers only allow audio to start from a gesture — pointerdown/keydown
     both qualify — so we prime once, on whichever comes first. */
  function primeAudio() {
    if (document.documentElement.dataset.sound === "off") return;
    try {
      const AC = window.AudioContext || (window as any).webkitAudioContext;
      if (!AC) return;
      if (!audioCtx) audioCtx = new AC();
      if (audioCtx.state === "suspended") void audioCtx.resume();
    } catch {
      /* priming is best-effort; playSweepSound still creates one lazily */
    }
  }
  window.addEventListener("pointerdown", primeAudio, { once: true });
  window.addEventListener("keydown", primeAudio, { once: true });

  document.querySelectorAll<HTMLElement>(".ba").forEach((ba) => {
    // Remove the sweeping state once the dust-erase overlay fades out.
    ba.addEventListener("animationend", (e) => {
      if ((e as AnimationEvent).animationName === "sweep-run") {
        ba.classList.remove("sweeping");
      }
    });

    // ── Sliding thumb ─────────────────────────────────────────────────────
    // Park the white pill over whichever tab is selected. Measured live, since
    // the tab labels change width between languages (and across a resize).
    const thumb = ba.querySelector<HTMLElement>(".ba-thumb");
    function positionThumb() {
      const active = ba.querySelector<HTMLElement>(
        '[data-ba][aria-pressed="true"]',
      );
      if (!thumb || !active) return;
      // offsetLeft/Width are relative to .ba-switch (the positioned ancestor),
      // which is exactly the thumb's containing block — so no extra math.
      thumb.style.setProperty("--thumb-x", `${active.offsetLeft}px`);
      thumb.style.setProperty("--thumb-w", `${active.offsetWidth}px`);
    }
    // Place it without animating on first paint, then enable the glide.
    positionThumb();
    requestAnimationFrame(() => thumb?.classList.remove("no-anim"));
    // Fonts can load after first paint and reflow the labels — realign then.
    document.fonts?.ready.then(positionThumb);
    // Keep aligned as the viewport or the active language (label widths) change.
    window.addEventListener("resize", positionThumb);
    new MutationObserver(positionThumb).observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["data-lang"],
    });

    ba.querySelectorAll<HTMLButtonElement>("[data-ba]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const mode = btn.dataset.ba!;
        const wasClean = ba.dataset.show === "after";
        ba.dataset.show = mode;
        ba.querySelectorAll<HTMLButtonElement>("[data-ba]").forEach((b) =>
          b.setAttribute("aria-pressed", String(b.dataset.ba === mode)),
        );
        positionThumb(); // glide the pill onto the newly selected tab
        // Sweep only when actually cleaning (slop → clean), never in reverse.
        if (mode === "after" && !wasClean && !reduceMotion.matches) {
          ba.classList.remove("sweeping");
          void ba.offsetWidth; // reflow so the animation restarts on re-click
          ba.classList.add("sweeping");
          // Match the sound's pace to the CSS tempo so strokes ride the band.
          const tempo =
            parseFloat(getComputedStyle(ba).getPropertyValue("--sweep-t")) || 1;
          playSweepSound(tempo); // brush strokes + gleam, timed to the wipe
        } else if (mode === "before") {
          // Flipping back mid-sweep: cancel it, or the returning slop pane
          // would still be wearing the half-finished erase mask.
          ba.classList.remove("sweeping");
        }
      });
    });
  });
</script>
